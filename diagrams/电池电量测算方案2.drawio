        <mxCell id="PJUP-OBpyC3OTBr9TddZ-10" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;设备电池电量表&lt;/h1&gt;&lt;p&gt;id&lt;/p&gt;&lt;p&gt;设备编号&lt;/p&gt;&lt;p&gt;换电次数&lt;/p&gt;&lt;p&gt;最新换电时间&lt;/p&gt;&lt;p&gt;电池规格&lt;/p&gt;&lt;p&gt;采集间隔&lt;/p&gt;&lt;p&gt;电池容量(减损后)&lt;/p&gt;" vertex="1">
          <mxGeometry height="255" width="180" x="1320" y="950" as="geometry" />
        </mxCell>
        <mxCell id="PJUP-OBpyC3OTBr9TddZ-11" edge="1" parent="1" source="PJUP-OBpyC3OTBr9TddZ-12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" target="PJUP-OBpyC3OTBr9TddZ-5">
