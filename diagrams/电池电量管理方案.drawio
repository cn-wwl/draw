        <mxCell id="RifOu2nllqv2r8CL3Mx8-11" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;设备电池电量表&lt;/h1&gt;&lt;p&gt;id&lt;/p&gt;&lt;p&gt;设备编号&lt;/p&gt;&lt;p&gt;换电次数&lt;/p&gt;&lt;p&gt;最新换电时间&lt;/p&gt;&lt;p&gt;电池规格&lt;/p&gt;&lt;p&gt;上报次数_偏移量&lt;/p&gt;&lt;p&gt;最后上报次数&lt;/p&gt;&lt;p&gt;可上报总次数&lt;/p&gt;" vertex="1">
